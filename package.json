{
    "name": "metadata-skeleton-offline-2",
    "version": "1.0.0",
    "main": "index.ts",
    "author": "EyeSeeTea",
    "license": "MIT",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "lint": "eslint src/{data,domain,scripts,types,utils}/**/*.ts --ext .ts",
        "start": "ts-node ./src/index.ts",
        "validate": "ts-node ./src/validateSchema.ts",
        "prettify": "prettier \"./**/*.{js,jsx,json,css,ts,tsx}\" --write",
        "metadata-build": "ts-node ./src/index.ts metadata build",
        "metadata-compare": "ts-node ./src/index.ts metadata compare"
    },
    "devDependencies": {
        "@types/node": "^22.9.0",
        "@typescript-eslint/eslint-plugin": "^8.32.0",
        "@typescript-eslint/parser": "^8.32.0",
        "eslint": "^9.26.0",
        "eslint-config-standard": "^17.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "arg": "^5.0.2",
        "cmd-ts": "^0.13.0",
        "typed-immutable-map": "^0.2.0"
    }
}
